{
  "name": "insure-web",
  "version": "0.1.0",
  "private": true,
  "description": "Insurance coverage overview dashboard for Singapore: upload policy PDFs (parsed in-browser), review, and see coverage by category with adequacy gaps.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:open-next": "open-next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:coverage": "node ../../packages/spec-test/dist/cli.js --spec specs/insure.yml --out spec-coverage.md",
    "test:reset": "node -e \"require('fs').rmSync('.spec-coverage',{recursive:true,force:true})\"",
    "test:spec": "npm run test:reset && npm run build && npm run test:unit && npm run test:e2e && npm run test:coverage"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.81",
    "@langchain/core": "^1.1.48",
    "@langchain/langgraph": "^1.3.3",
    "ai": "^6.0.193",
    "next": "^16.0.0",
    "pdfjs-dist": "^4.7.76",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@opennextjs/aws": "^4.0.3",
    "@platform/spec-test": "*",
    "@playwright/test": "^1.48.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.60.0",
    "vitest": "^2.0.0"
  }
}
